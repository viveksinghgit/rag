# Example terraform.tfvars file
# Copy to terraform.tfvars and fill in your values
# DO NOT COMMIT terraform.tfvars to Git (contains secrets!)

resource_group_name = "rag-prod-rg"
app_name            = "rag-prod"
environment         = "prod"
azure_region        = "eastus"

# Get Groq API key: https://console.groq.com/keys
litellm_groq_api_key = "gsk_xxxxxxxxxxxxxxxxxxxx"

# Get Mistral API key (optional): https://console.mistral.ai/api-keys/
litellm_mistral_api_key = "your-mistral-key-here"

# Generate secure key for Qdrant
qdrant_admin_key = "generate-secure-random-key-here"

# Resource sizes (adjust for your needs)
app_service_sku  = "B1"  # B1: $13/mo, B2: $50/mo, S1: $100/mo
qdrant_cpu       = 1     # cores
qdrant_memory_gb = 1     # GB
qdrant_storage_gb = 10   # GB

tags = {
  project     = "RAG-Azure"
  managedBy   = "Terraform"
  costCenter  = "engineering"
}
