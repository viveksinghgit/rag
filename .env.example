# ==============================================================================
# RAG System Environment Configuration
# Copy this to .env and update with your values
# ==============================================================================

# Application Settings
DEBUG=true
ENVIRONMENT=local
HOST=0.0.0.0
PORT=8000

# Qdrant Vector Database Configuration
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=documents
QDRANT_VECTOR_SIZE=768
QDRANT_RECREATE_ON_VECTOR_MISMATCH=true
# See: qdrant-admin.key (add your key there)
QDRANT_ADMIN_KEY=local-rag-admin-key
QDRANT_ADMIN_KEY_FILE=./secrets/qdrant-admin.key

# ==============================================================================
# LLM Provider Selection
# ==============================================================================
# Choose ONE provider: 'ollama' or 'litellm'

# Option 1: Local Ollama (Recommended for testing)
# - Free, runs locally
# - Auto-downloads models (~400MB for qwen2.5:0.5b plus embedding model)
# - No API keys needed
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama

# Ollama Configuration
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5:0.5b
# Larger alternatives after increasing WSL memory: llama3.2:1b, qwen2.5:1.5b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=180

# Option 2: Cloud LLM with LiteLLM (uncomment to use)
# LLM_PROVIDER=litellm
# EMBEDDING_PROVIDER=litellm

# ==============================================================================
# LiteLLM Configuration (Cloud Providers)
# ==============================================================================
# Only needed if LLM_PROVIDER=litellm

# Groq API (Free tier available)
# Get key at: https://console.groq.com
# Store in: secrets/groq-api.key
LITELLM_GROQ_API_KEY_FILE=./secrets/groq-api.key

# Mistral API
# Get key at: https://console.mistral.ai
# Store in: secrets/mistral-api.key
LITELLM_MISTRAL_API_KEY_FILE=./secrets/mistral-api.key

# OpenAI API (for ChatGPT/GPT-4)
# Get key at: https://platform.openai.com
# Store in: secrets/openai-api.key
LITELLM_API_KEY_FILE=./secrets/openai-api.key

# LiteLLM Model Selection
LITELLM_LLM_MODEL=groq/mixtral-8x7b-32768
LITELLM_EMBEDDING_MODEL=mistral-embed

# ==============================================================================
# RAG Pipeline Configuration
# ==============================================================================

# Document Processing
EMBEDDING_DIMENSION=768
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Retrieval Settings
RETRIEVAL_LIMIT=5
SIMILARITY_THRESHOLD=0.5
CONTEXT_WINDOW_LIMIT=2000

# ==============================================================================
# Azure Blob Storage (Optional)
# ==============================================================================
# For storing documents in Azure instead of locally

AZURE_STORAGE_ACCOUNT_NAME=
# Store key in: secrets/azure-credentials.env
AZURE_STORAGE_ACCOUNT_KEY_FILE=./secrets/azure-credentials.env
AZURE_STORAGE_CONTAINER=documents

# ==============================================================================
# CORS Settings
# ==============================================================================
# In production, specify allowed origins instead of "*"
# CORS_ORIGINS=["https://example.com", "https://app.example.com"]

# ==============================================================================
# Quick Start
# ==============================================================================
# 
# 1. Copy this file: cp .env.example .env
# 
# 2. For LOCAL testing (Ollama):
#    - Keep defaults above (LLM_PROVIDER=ollama)
#    - Run: docker-compose up --build
#    - First run: Ollama downloads model (~5GB, 2-5 min)
# 
# 3. For CLOUD testing (Groq/Mistral):
#    - Set LLM_PROVIDER=litellm
#    - Add API key from: https://console.groq.com
#    - Run: docker-compose up --build
# 
# 4. After services are healthy:
#    - Ingest docs: docker exec rag-backend python scripts/ingest_sample_documents.py --sample
#    - Test: docker exec rag-backend python scripts/test_rag_e2e.py
#    - Chat: http://localhost:3000
# 
# ==============================================================================
