# Application Settings
DEBUG=false
ENVIRONMENT=local
HOST=0.0.0.0
PORT=8000

# Qdrant Vector Database
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=documents
QDRANT_VECTOR_SIZE=768
QDRANT_RECREATE_ON_VECTOR_MISMATCH=true
QDRANT_ADMIN_KEY=local-rag-admin-key

# Local Ollama Configuration
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=180

# LiteLLM Configuration
# Get your API keys from:
# - Groq: https://console.groq.com/keys
# - Mistral: https://console.mistral.ai/api-keys/
LITELLM_GROQ_API_KEY=
LITELLM_MISTRAL_API_KEY=
LITELLM_API_KEY=

# Embedding & LLM Models
LITELLM_EMBEDDING_MODEL=mistral-embed
LITELLM_LLM_MODEL=groq/mixtral-8x7b-32768

# RAG Configuration
RETRIEVAL_LIMIT=5
SIMILARITY_THRESHOLD=0.5
CONTEXT_WINDOW_LIMIT=2000

# Document Processing
EMBEDDING_DIMENSION=768
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Azure Storage (Optional, for document persistence)
AZURE_STORAGE_ACCOUNT_NAME=your-account-name
AZURE_STORAGE_ACCOUNT_KEY=your-account-key
AZURE_STORAGE_CONTAINER=documents
